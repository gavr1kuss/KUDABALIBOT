# Telegram Bot (от @BotFather)
BOT_TOKEN=12345:YOUR_BOT_TOKEN

# Telegram API (my.telegram.org) — для Telethon-сканера
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your_api_hash_here

# AI (любой OpenAI-совместимый провайдер: DeepSeek, Claude через vibecode-claude и т.д.)
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ID админа в Telegram (узнать у @userinfobot)
ADMIN_ID=123456789

# База данных
DATABASE_URL=sqlite+aiosqlite:///events.db

# Сборщик
HISTORY_DAYS=2
SCAN_INTERVAL_HOURS=6

# Supabase ключи для ежедневного парсинга сайтов
# balievents.co — anon key из DevTools Network при загрузке https://balievents.co/events
BALIEVENTS_URL=https://uyueqyedxphgdkaiwwsj.supabase.co/rest/v1/public_events
BALIEVENTS_KEY=
# app.bali.com — anon key из DevTools Network при загрузке https://app.bali.com/events
APPBALI_URL=https://wbwgwytdqubtrdxfbjrr.supabase.co/rest/v1/events
APPBALI_KEY=
